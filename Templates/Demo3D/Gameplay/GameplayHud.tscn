[gd_scene format=3]

[ext_resource type="Script" path="res://Templates/Demo3D/Gameplay/GameplayHud.cs" id="1_hud"]

[node name="GameplayHud" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
script = ExtResource("1_hud")
ProgressLabelPath = NodePath("Margin/VBox/ProgressLabel")
DeviceLabelPath = NodePath("Margin/VBox/DeviceLabel")
JumpBindingLabelPath = NodePath("Margin/VBox/RebindPanel/RebindVBox/JumpBindingLabel")
RebindJumpButtonPath = NodePath("Margin/VBox/RebindPanel/RebindVBox/ButtonRow/RebindJumpButton")
RestoreJumpButtonPath = NodePath("Margin/VBox/RebindPanel/RebindVBox/ButtonRow/RestoreJumpButton")
RebindStatusLabelPath = NodePath("Margin/VBox/RebindPanel/RebindVBox/RebindStatusLabel")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 300.0
grow_horizontal = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.93, 1, 1)
theme_override_font_sizes/font_size = 24
text = "收集所有能量核心"

[node name="ProgressLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "能量核心：0 / 5"

[node name="DeviceLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.55, 0.85, 1, 1)
text = "输入设备：等待输入"

[node name="HintLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.8, 0.85, 1)
text = "WASD 移动 · 当前绑定跳跃 · 鼠标旋转视角 · Esc 释放鼠标/取消改键"

[node name="RebindPanel" type="PanelContainer" parent="Margin/VBox"]
custom_minimum_size = Vector2(420, 0)
layout_mode = 2

[node name="RebindVBox" type="VBoxContainer" parent="Margin/VBox/RebindPanel"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="JumpBindingLabel" type="Label" parent="Margin/VBox/RebindPanel/RebindVBox"]
layout_mode = 2
text = "跳跃主绑定：Space"

[node name="ButtonRow" type="HBoxContainer" parent="Margin/VBox/RebindPanel/RebindVBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="RebindJumpButton" type="Button" parent="Margin/VBox/RebindPanel/RebindVBox/ButtonRow"]
layout_mode = 2
text = "重新绑定跳跃"

[node name="RestoreJumpButton" type="Button" parent="Margin/VBox/RebindPanel/RebindVBox/ButtonRow"]
layout_mode = 2
text = "恢复默认"

[node name="RebindStatusLabel" type="Label" parent="Margin/VBox/RebindPanel/RebindVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.8, 0.86, 0.92, 1)
text = "Esc 释放鼠标后可点击按钮体验运行时改键"
