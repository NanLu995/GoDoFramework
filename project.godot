; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GoDoFramework"
run/main_scene="uid://bjrtjk0nd7c4l"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[autoload]

GUIDE="*uid://p2jwrgjcbexr"
GuideCs="*uid://dwc608aemhafg"
GoDoRuntime="*res://addons/godo_framework/Core/GoDoRuntime.tscn"
PhantomCameraManager="*uid://duq6jhf6unyis"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="GoDoFramework"

[editor_plugins]

enabled=PackedStringArray("res://addons/godo_framework/plugin.cfg", "res://addons/guideCS/guide/plugin.cfg", "res://addons/guideCS/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://Localization/en.po", "res://Localization/fr.po", "res://Localization/ar.po")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
